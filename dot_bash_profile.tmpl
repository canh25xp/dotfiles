export EDITOR=nvim
export PAGER=less
export MANPAGER='nvim +Man!'
export NVIM_APPNAME=nvim-lazy
export STARSHIP_CONFIG=$HOME/.config/starship/starship.toml
export LESSHISTFILE="$HOME/.lesshst"

export P4ENVIRO="$HOME/.config/p4/p4enviro"
export P4ALIASES="$HOME/.config/p4/p4aliases"
{{- if .wsl }}
export P4TICKETS="$USERPROFILE/.p4tickets"
{{- else }}
export P4TICKETS="$HOME/.p4tickets"
{{- end }}

export FZF_DEFAULT_OPTS='--height=50% --multi --layout=reverse --info=inline'

{{ if .wsl -}}
export FIGNORE=".dll:.DLL"
{{ end -}}

if [ -d "$HOME/android" ]; then
    export ANDROID_HOME="$HOME/android"
    export PATH="$PATH:$ANDROID_HOME/cmdline-tools/latest/bin"
    export PATH="$PATH:$ANDROID_HOME/platform-tools"
    # Add latest build-tools version automatically
    latest_build_tools=$(ls -1 "$ANDROID_HOME/build-tools" | sort -V | tail -n1)
    export PATH="$PATH:$ANDROID_HOME/build-tools/$latest_build_tools"
fi

if [ -d "$HOME/.jdks" ]; then
    latest_jdk=$(find "$HOME/.jdks" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort -V | tail -n1)

    if [ -n "$latest_jdk" ]; then
        export JAVA_HOME="$HOME/.jdks/$latest_jdk"
        export PATH="$JAVA_HOME/bin:$PATH"
    fi
fi

{{ if .wsl -}}
export DONT_PROMPT_WSL_INSTALL=true
export PATH="$LOCALAPPDATA/Programs/Microsoft VS Code/bin:$PATH"
export PATH="$PATH:/mnt/c/Program Files/Neovide"
export PATH="$PATH:/mnt/c/Program Files/PowerShell/7"
{{ end -}}

export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent.socket"

if [ -d "$HOME/bin" ]; then
    PATH="$HOME/bin:$PATH"
fi

if [ -d "$HOME/.local/bin" ]; then
    PATH="$HOME/.local/bin:$PATH"
fi

if [ -d "$HOME/.cargo/bin" ]; then
    PATH="$HOME/.cargo/bin:$PATH"
fi

if [ -d "$HOME/go/bin" ]; then
    PATH="$HOME/go/bin:$PATH"
fi

# if running bash
if [ -n "$BASH_VERSION" ]; then
    # include .bashrc if it exists
    if [ -f "$HOME/.bashrc" ]; then
        . "$HOME/.bashrc"
    fi
fi

# Start X automatically on tty1
if [ -z "$DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
    startx
fi
