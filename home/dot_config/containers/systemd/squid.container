[Unit]
Description=Squid Proxy Container

[Container]
Image=docker.io/ubuntu/squid
ContainerName=squid
PublishPort=3128:3128
Volume=%h/.config/squid/allow-wifi-proxy.conf:/etc/squid/conf.d/allow-wifi-proxy.conf:ro
Volume=%h/.cache/squid:/var/spool/squid
Volume=%h/.local/share/squid:/var/log/squid

[Service]
Restart=always

[Install]
WantedBy=default.target
