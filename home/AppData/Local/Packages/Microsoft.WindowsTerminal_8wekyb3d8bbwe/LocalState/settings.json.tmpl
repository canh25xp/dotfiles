{{/* chezmoi:template:line-endings=lf */}}
{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": [],
    "centerOnLaunch": true,
    "compatibility.allowHeadless": true,
    "copyFormatting": "none",
    "copyOnSelect": true,
    "defaultProfile": {{ if eq .defaultShell "powershell" -}} "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}" {{- else if eq .defaultShell "pwsh" -}} "{574e775e-4f2a-5b96-ac1e-a2962a402336}" {{- else -}} "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}" {{- end }},
    "disableAnimations": false,
    "disabledProfileSources": [
        "Windows.Terminal.Wsl",
        "Windows.Terminal.Azure"
    ],
    "initialRows": 40,
    "keybindings": [
        { "keys": "alt+up", "id": null },
        { "keys": "alt+down", "id": null },
        { "keys": "alt+left", "id": null },
        { "keys": "alt+right", "id": null },
        { "keys": "ctrl+c", "id": null },
        { "keys": "ctrl+v", "id": null },
        { "keys": "ctrl+,", "id": null },

        { "keys": "f2", "id": "Terminal.OpenTabRenamer" },
        { "keys": "ctrl+shift+f", "id": "Terminal.FindText" },
        { "keys": "ctrl+shift+z", "id": "Terminal.ToggleFocusMode" },
        { "keys": "ctrl+shift+l", "id": "Terminal.ClearBuffer" },
        { "keys": "ctrl+shift+,", "id": "Terminal.OpenSettingsUI" },
        { "keys": "ctrl+alt+shift+comma", "id": "Terminal.OpenDefaultSettingsFile" },

        { "keys": "ctrl+shift+k", "id": "Terminal.ScrollUp" },
        { "keys": "ctrl+shift+j", "id": "Terminal.ScrollDown" },
        { "keys": "ctrl+shift+pgup", "id": "Terminal.ScrollUpPage" },
        { "keys": "ctrl+shift+pgdn", "id": "Terminal.ScrollDownPage" },

        { "keys": "alt+k", "id": "Terminal.MoveFocusUp" },
        { "keys": "alt+j", "id": "Terminal.MoveFocusDown" },
        { "keys": "alt+h", "id": "Terminal.MoveFocusLeft" },
        { "keys": "alt+l", "id": "Terminal.MoveFocusRight" },
        { "keys": "ctrl+alt+k", "id": "Terminal.MoveFocusUp" },
        { "keys": "ctrl+alt+j", "id": "Terminal.MoveFocusDown" },
        { "keys": "ctrl+alt+h", "id": "Terminal.MoveFocusLeft" },
        { "keys": "ctrl+alt+l", "id": "Terminal.MoveFocusRight" },
        { "keys": "ctrl+alt+n", "id": "Terminal.MoveFocusNextInOrder" },
        { "keys": "ctrl+alt+p", "id": "Terminal.MoveFocusPreviousInOrder" },
        { "keys": "ctrl+alt+o", "id": "Terminal.MoveFocusPrevious" },
        { "keys": "ctrl+alt+enter", "id": "Terminal.TogglePaneZoom" },

        { "keys": "ctrl+alt+shift+plus", "id": "Terminal.ResizePaneUp" },
        { "keys": "ctrl+alt+shift+minus", "id": "Terminal.ResizePaneDown" },
        { "keys": "ctrl+shift+minus", "id": "Terminal.ResizePaneLeft" },
        { "keys": "ctrl+shift+plus", "id": "Terminal.ResizePaneRight" },
        { "keys": "ctrl+shift+\\", "id": "Terminal.DuplicatePaneAuto" },
        { "keys": "ctrl+alt+shift+\\", "id": "Terminal.ToggleSplitOrientation" }
    ],
    "launchMode": "default",
    "newTabMenu": [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles":
    {
        "defaults":
        {
            "backgroundImage": {{ .wallpaper | quote }},
            "backgroundImageOpacity": {{ if .terminalBackground -}} 0.15 {{- else -}} 0 {{- end }},
            "closeOnExit": "always",
            "colorScheme": {
                "dark": "Catppuccin Mocha",
                "light": "Catppuccin Latte"
            },
            "cursorShape": "filledBox",
            "experimental.repositionCursorWithMouse": false,
            "font": {
                "cellHeight": "1.2",
                "face": "CaskaydiaMono Nerd Font",
                "features": {},
                "size": 13
            },
            "padding": "0",
            "scrollbarState": "visible",
            "showMarksOnScrollbar": true
        },
        "list": [
            {
                "commandline": "%SystemRoot%\\System32\\cmd.exe",
                "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
                "hidden": true,
                "name": "Command Prompt"
            },
            {
                "commandline": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "hidden": false,
                "name": "PowerShell Legacy"
            },
            {
                "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
                "hidden": false,
                "name": "PowerShell",
                "source": "Windows.Terminal.PowershellCore"
            },
            {
                "guid": "{a3a2e83a-884a-5379-baa8-16f193a13b21}",
                "hidden": false,
                "name": "PowerShell Preview",
                "source": "Windows.Terminal.PowershellCore"
            },
            {
                "guid": "{0c577fb7-dd57-5da6-a2bf-5e594f484dfe}",
                "hidden": false,
                "name": "WSL",
                "source": "Microsoft.WSL"
            },
            {
                "backgroundImage": {{ .wallpaperAlt | quote }},
                "commandline": "wsl.exe -d Debian",
                "guid": "{58ad8b0c-3ef8-5f4d-bc6f-13e4c00f2530}",
                "hidden": false,
                "icon": "%USERPROFILE%\\Pictures\\Assets\\debian.ico",
                "name": "Debian",
                "source": "Microsoft.WSL",
                "scrollbarState": "hidden",
                "startingDirectory": "~"
            },
            {
                "backgroundImage": {{ .wallpaperAlt | quote }},
                "commandline": "wsl.exe -d Ubuntu",
                "guid": "{4e4b4c84-0314-4889-a424-9bd273a7a2b6}",
                "hidden": false,
                "icon": "%USERPROFILE%\\Pictures\\Assets\\ubuntu.ico",
                "scrollbarState": "hidden",
                "name": "Ubuntu",
                "startingDirectory": "~"
            },
            {
                "commandline": "ssh tablet",
                "guid": "{12d556de-1d3f-4143-b81a-aedfd7ccca04}",
                "hidden": false,
                "scrollbarState": "hidden",
                "name": "ssh (tablet)"
            },
            {
                "commandline": "ssh wifiteam-jump-netgear",
                "guid": "{4477d33a-9a8a-4da5-bf1f-f14e14184c01}",
                "hidden": false,
                "scrollbarState": "always",
                "name": "ssh (wifiteam-jump-netgear)"
            }
        ]
    },
    "schemes": [],
    "tabSwitcherMode": "inOrder",
    "theme": {
        "dark": "Catppuccin Mocha",
        "light": "Catppuccin Latte"
    },
    "themes": [
        {
            "name": "Catppuccin Frappe",
            "tab": {
                "background": "#303446FF",
                "iconStyle": "default",
                "showCloseButton": "always",
                "unfocusedBackground": null
            },
            "tabRow": {
                "background": "#292C3CFF",
                "unfocusedBackground": "#232634FF"
            },
            "window": {
                "applicationTheme": "dark",
                "experimental.rainbowFrame": false,
                "frame": null,
                "unfocusedFrame": null,
                "useMica": false
            }
        },
        {
            "name": "Catppuccin Latte",
            "tab": {
                "background": "#EFF1F5FF",
                "iconStyle": "default",
                "showCloseButton": "always",
                "unfocusedBackground": null
            },
            "tabRow": {
                "background": "#E6E9EFFF",
                "unfocusedBackground": "#DCE0E8FF"
            },
            "window": {
                "applicationTheme": "light",
                "experimental.rainbowFrame": false,
                "frame": null,
                "unfocusedFrame": null,
                "useMica": false
            }
        },
        {
            "name": "Catppuccin Macchiato",
            "tab": {
                "background": "#24273AFF",
                "iconStyle": "default",
                "showCloseButton": "always",
                "unfocusedBackground": null
            },
            "tabRow": {
                "background": "#1E2030FF",
                "unfocusedBackground": "#181926FF"
            },
            "window": {
                "applicationTheme": "dark",
                "experimental.rainbowFrame": false,
                "frame": null,
                "unfocusedFrame": null,
                "useMica": false
            }
        },
        {
            "name": "Catppuccin Mocha",
            "tab": {
                "background": "#1E1E2EFF",
                "iconStyle": "default",
                "showCloseButton": "hover",
                "unfocusedBackground": null
            },
            "tabRow": {
                "background": "#181825FF",
                "unfocusedBackground": "#11111BFF"
            },
            "window": {
                "applicationTheme": "system",
                "experimental.rainbowFrame": false,
                "frame": null,
                "unfocusedFrame": null,
                "useMica": false
            }
        }
    ],
    "useAcrylicInTabRow": true,
    "warning.confirmCloseAllTabs": false
}
