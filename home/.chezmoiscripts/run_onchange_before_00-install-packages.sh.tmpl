{{ if .linux -}}
#!/usr/bin/env bash

{{ else if .android -}}
#!/data/data/com.termux/files/usr/bin/bash

{{ end -}}

set -euo pipefail

# --- Helper functions ---

is_tty() { [ -t 0 ]; }

banner() {
  echo "================================================================================"
  echo "[Chezmoi] $*"
}

confirm() {
  local prompt="${1:-Continue?} (Y/n): "
  if is_tty; then
    read -p "$prompt" answer
    answer="${answer:-Y}"
  else
    answer="Y"
  fi
  [[ "$answer" =~ ^[Yy]$ ]]
}

# Build the package list from template data, optionally including desktop packages
build_package_list() {
  local -a pkgs=()
  {{- if .linux }}
  {{- range .packages.linux.apt }}
  pkgs+=("{{ . }}")
  {{- end }}
  {{- else if .android }}
  {{- range .packages.termux.pkg }}
  pkgs+=("{{ . }}")
  {{- end }}
  {{- end }}

  {{- if .linux }}
  # Include desktop packages only when interactive (TTY)
  if is_tty; then
    {{- range index .packages.linux "apt-desktop" }}
    pkgs+=("{{ . }}")
    {{- end }}
  fi
  {{- end }}

  printf '%s\n' "${pkgs[@]}"
}

# Let the user edit the package list in a temp file (TTY only)
edit_package_list() {
  local tmpfile="$1"
  if is_tty; then
    editor "$tmpfile"
  fi
}

# Read package names from file, skipping blank lines and comments
read_package_list() {
  local tmpfile="$1"
  local -a result=()
  while IFS= read -r line || [ -n "$line" ]; do
    # Trim leading/trailing whitespace
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    # Skip empty lines and comments
    [[ -z "$line" || "$line" == \#* ]] && continue
    result+=("$line")
  done <"$tmpfile"
  printf '%s\n' "${result[@]}"
}

# Validate packages exist in apt cache, split into available and missing
validate_packages() {
  local -a pkgs=("$@")
  available_packages=()
  missing_packages=()
  for pkg in "${pkgs[@]}"; do
    if apt-cache show "$pkg" >/dev/null 2>&1; then
      available_packages+=("$pkg")
    else
      missing_packages+=("$pkg")
    fi
  done
}

# --- Main ---

banner "Installing packages"

if ! confirm "Continue?"; then
  echo "Canceled"
  exit 0
fi

temp_file=$(mktemp)
trap 'rm -f "$temp_file"' EXIT

build_package_list >"$temp_file"
edit_package_list "$temp_file"

# Read edited package list
mapfile -t selected_packages < <(read_package_list "$temp_file")

if [[ ${#selected_packages[@]} -eq 0 ]]; then
  echo "No packages selected. Exiting."
  exit 1
fi

# Early exit: skip apt-get update/install when all packages are already present
all_installed=true
for pkg in "${selected_packages[@]}"; do
  if ! dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null | grep -q "install ok installed"; then
    all_installed=false
    break
  fi
done

if $all_installed; then
  echo "All packages already installed. Skipping."
  exit 0
fi

{{ if .linux -}} sudo {{ end -}} apt-get update

# Validate packages
available_packages=()
missing_packages=()
validate_packages "${selected_packages[@]}"

if ((${#missing_packages[@]} > 0)); then
  echo
  echo "Warning: The following packages were not found and will be skipped:"
  for pkg in "${missing_packages[@]}"; do
    echo " - $pkg"
  done
fi

if ((${#available_packages[@]} == 0)); then
  echo
  echo "No valid packages to install. Exiting."
  exit 1
fi

echo
echo "The following packages will be installed:"
for pkg in "${available_packages[@]}"; do
  echo " - $pkg"
done

if ! confirm "Do you want to proceed with the installation?"; then
  echo "Installation canceled."
  exit 0
fi

{{ if .linux -}} sudo {{ end -}} apt-get install "${available_packages[@]}" -y
