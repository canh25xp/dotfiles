{{ if .linux -}}
#!/usr/bin/env bash

{{ else if .android -}}
#!/data/data/com.termux/files/usr/bin/bash

{{ end -}}

set -euo pipefail

# --- Helper functions ---

is_tty() { [ -t 0 ]; }

banner() {
  echo "================================================================================"
  echo "[Chezmoi] $*"
}

# --- Main ---

KEY_FILE="${HOME}/.config/chezmoi/key.txt"
ENC_FILE="${HOME}/.local/share/chezmoi/.key.txt.age"

if [ -f "$KEY_FILE" ]; then
  exit 0
fi

# Skip decrypt if no TTY (non-interactive mode)
if ! is_tty; then
  echo "[Chezmoi] No TTY detected, skipping key decryption"
  exit 0
fi

banner "decrypt private key"
mkdir -p "${HOME}/.config/chezmoi"

attempts=0
while [ "$attempts" -lt 3 ]; do
  if chezmoi age decrypt --output "$KEY_FILE" --passphrase "$ENC_FILE"; then
    chmod 600 "$KEY_FILE"
    exit 0
  fi

  attempts=$((attempts + 1))
  echo "Decrypt failed ($attempts/3), try again..."
done

exit 1
