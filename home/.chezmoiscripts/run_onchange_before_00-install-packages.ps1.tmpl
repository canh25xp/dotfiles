#!/usr/bin/env pwsh

# --- Helper functions ---

function Test-TTY {
  -not [Console]::IsInputRedirected
}

function Write-Banner {
  param([string]$Message)
  Write-Host "================================================================================"
  Write-Host "[Chezmoi] $Message"
}

function Confirm-Action {
  param([string]$Prompt = "Continue?")
  if (Test-TTY) {
    $answer = Read-Host "$Prompt (Y/n)"
    if ($null -eq $answer -or $answer -eq "") { $answer = "Y" }
  } else {
    $answer = "Y"
  }
  $answer -match "^[Yy]$"
}

# --- Main ---

Write-Banner "Install winget packages"

if (-not (Confirm-Action "Do you want to install winget packages?")) {
  Write-Host "Skip"
  exit 0
}

winget install {{- range .packages.windows.winget }} {{ . }} {{- end }}
