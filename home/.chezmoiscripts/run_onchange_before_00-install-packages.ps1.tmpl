Write-Host "================================================================================"
Write-Host "[Chezmoi] Install winget packages"

# TTY detection: skip interactive operations if no TTY
# In PowerShell, check if stdin is redirected
$IsInteractive = -not [Console]::IsInputRedirected

if ($IsInteractive) {
    $confirmation = Read-Host "Do you want to install winget packages? (Y/n)"
} else {
    $confirmation = "Y"
}

if ($confirmation -notmatch "^[Yy]$") {
  Write-Host "Skip"
  exit
}

winget install {{- range .packages.windows.winget }} {{ . }} {{- end }}
