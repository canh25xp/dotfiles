#! /bin/bash
# Stolen from https://github.com/matan-h/adb-shell

choose_device() {
    # Respect existing selection
    if [ -n "$ANDROID_SERIAL" ]; then
        return
    fi

    # Collect full device info lines
    mapfile -t DEVICE_LINES < <(adb devices -l | awk 'NR>1 && $2=="device"')

    if [ "${#DEVICE_LINES[@]}" -eq 0 ]; then
        echo "No adb devices connected" >&2
        exit 1
    fi

    # Extract serials
    mapfile -t SERIALS < <(printf '%s\n' "${DEVICE_LINES[@]}" | awk '{print $1}')

    # Only one → auto pick
    if [ "${#SERIALS[@]}" -eq 1 ]; then
        export ANDROID_SERIAL="${SERIALS[0]}"
        return
    fi

    echo "Multiple adb devices detected:"
    for i in "${!DEVICE_LINES[@]}"; do
        serial="${SERIALS[$i]}"
        line="${DEVICE_LINES[$i]}"

        model=$(grep -o 'model:[^ ]*' <<<"$line" | cut -d: -f2)
        product=$(grep -o 'product:[^ ]*' <<<"$line" | cut -d: -f2)

        printf " [%d] %s  (model:%s product:%s)\n" \
            "$((i + 1))" "$serial" "${model:-?}" "${product:-?}"
    done

    printf "Choose device: "
    read -r idx

    if ! [[ "$idx" =~ ^[0-9]+$ ]] || [ "$idx" -lt 1 ] || [ "$idx" -gt "${#SERIALS[@]}" ]; then
        echo "Invalid selection" >&2
        exit 1
    fi

    export ANDROID_SERIAL="${SERIALS[$((idx - 1))]}"
}

choose_device

STARTUP=/sdcard/.mkshrc
adb shell "[ -f $STARTUP ] || exit 6"
last_exit_status=$?

if [ $last_exit_status -eq 6 ]; then
    echo "file not found, push with adb"
    adb push "$(dirname "$0")/.mkshrc" $STARTUP

elif [ $last_exit_status -eq 1 ]; then # adb error
    exit 1
fi
# for most shells, '-o emacs -o vi-tabcomplete' is the default, but for some it isn't.
adb shell -t "HOME='/sdcard' ENV='$STARTUP' sh -i -o emacs -o vi-tabcomplete"
